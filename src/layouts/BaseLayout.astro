---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props { title: string; description?: string; }
const { title, description = 'Explore interior design styles by look, room and palette — a visual AI style atlas with shop-the-look ideas.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/images/imaginary-interiors-icon.webp', Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="n8D4vavY-M0yYzXjKQoskqjSDiunbn0u9DPN-umcKGk" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/webp" href="/images/imaginary-interiors-icon.webp" />
  <link rel="apple-touch-icon" href="/images/imaginary-interiors-icon.webp" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="generator" content={Astro.generator} />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <script is:inline>window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };</script>
  <script defer src="/_vercel/insights/script.js"></script>
</body>
</html>
