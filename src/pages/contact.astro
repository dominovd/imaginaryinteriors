---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = 'info@imaginaryinteriors.com';
---
<BaseLayout title="Contact — Imaginary Interiors" description="Get in touch with Imaginary Interiors.">
  <div class="wrap">
    <section class="hero" style="grid-template-columns:1fr;padding-bottom:10px">
      <div>
        <div class="eyebrow">Contact</div>
        <h1>Get in touch</h1>
        <p class="sub">Questions, feedback or partnership ideas — we'd love to hear from you.</p>
      </div>
    </section>

    <section>
      <div class="prose">
        <p>The best way to reach us is by email:</p>
        <p><a href={`mailto:${email}`}>{email}</a></p>

        <h2>Partnerships &amp; press</h2>
        <p>{/* TODO: replace with your own copy. */}
          For brand collaborations, affiliate partnerships or press enquiries, email us at
          <a href={`mailto:${email}`}> {email}</a> and we'll get back to you.</p>

        <h2>Response time</h2>
        <p>We typically reply within a few business days.</p>
      </div>
    </section>
  </div>
</BaseLayout>
