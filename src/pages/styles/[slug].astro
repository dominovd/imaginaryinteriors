---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Placeholder from '../../components/Placeholder.astro';
import Photo from '../../components/Photo.astro';
import { styles, getStyle } from '../../data/styles.js';
import { comboRoomList } from '../../data/combos.js';

export function getStaticPaths() {
  return styles.map((s) => ({ params: { slug: s.slug }, props: { style: s } }));
}

const { style } = Astro.props;
const s = style;
const related = (s.related || []).map(getStyle).filter(Boolean);
const showShop = false; // temporarily hidden — flip to true to restore Shop the look

// Starter structure — filled per style in styles.js over time.
const DEFAULT_SWATCHES = [
  { name: 'Color 1', hex: '#efe9dc' },
  { name: 'Color 2', hex: '#cabfa8' },
  { name: 'Color 3', hex: '#a49e93' },
  { name: 'Color 4', hex: '#5f5b52' },
  { name: 'Color 5', hex: '#2f2c28' },
];
const DEFAULT_MATERIALS = [
  { label: 'Wood', tone: 'walnut' },
  { label: 'Textile', tone: 'cream' },
  { label: 'Metal', tone: 'dark' },
  { label: 'Stone', tone: 'stone' },
];
const swatches = s.swatches && s.swatches.length ? s.swatches : DEFAULT_SWATCHES;
const materialTiles = s.materialTiles && s.materialTiles.length ? s.materialTiles : DEFAULT_MATERIALS;
const roomSlugByLabel = {
  'Living room': 'living-room',
  'Small office': 'home-office',
  'Home office': 'home-office',
  'Cabin bedroom': 'bedroom',
  Bedroom: 'bedroom',
  'Open kitchen': 'kitchen',
  Kitchen: 'kitchen',
  'Reading corner': 'living-room',
  Entryway: 'entryway-hallway',
};
const roomIdeas = s.roomIdeas && s.roomIdeas.length
  ? s.roomIdeas.map((r) => ({
      ...r,
      slug: roomSlugByLabel[r.label] || r.label.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''),
      name: r.label,
    }))
  : comboRoomList;
const comparisonRows = (s.comparisons || []).map((row) => {
  const slug = row.style.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  const linkedStyle = styles.find((item) => item.slug === slug || item.name.toLowerCase() === row.style.toLowerCase());
  return { ...row, href: linkedStyle ? `/styles/${linkedStyle.slug}` : null };
});
const faqJson = s.faqs && s.faqs.length
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: s.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    })
  : null;

const shopIcons = ['table','sofa','lamp','planter','rug','art'];
function icon(kind) {
  const map = {
    table: '<path d="M4 18v-5a2 2 0 012-2h12a2 2 0 012 2v5M6 11V8a2 2 0 012-2h8a2 2 0 012 2v3M5 18h14"/>',
    sofa: '<path d="M4 18v-5a2 2 0 012-2h12a2 2 0 012 2v5M6 11V8a2 2 0 012-2h8a2 2 0 012 2v3"/>',
    lamp: '<path d="M9 3h6l2 6H7l2-6zM12 9v9M8 21h8"/>',
    planter: '<path d="M6 10h12l-1 8a2 2 0 01-2 2H9a2 2 0 01-2-2l-1-8zM12 10c0-3 2-5 5-5"/>',
    rug: '<rect x="4" y="6" width="16" height="12" rx="1"/><path d="M4 10h16M4 14h16"/>',
    art: '<rect x="5" y="4" width="14" height="16" rx="1"/><path d="M8 14l3-3 5 5"/>',
  };
  return map[kind] || map.art;
}
---
<BaseLayout title={`${s.title} — Imaginary Interiors`} description={s.seoDescription || s.tagline} noindex={!s.indexed}>
  {faqJson && <script type="application/ld+json" set:html={faqJson}></script>}
  <div class="wrap">
    <div class="crumb"><a href="/styles">Styles</a> / {s.name}</div>

    <!-- HERO -->
    <section class="hubhero">
      <div>
        <div class="eyebrow">Style hub</div>
        <h1>{s.title}</h1>
        <p class="sub">{s.tagline}</p>
        <div class="cta">
          <button class="btn" id="savebtn" data-slug={s.slug}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6 3h12v18l-6-4-6 4z"/></svg> <span class="savelbl">Save style</span></button>
          {showShop && <a class="btn ghost" href="#shop">Shop the look →</a>}
        </div>
      </div>
      <div class="hubcollage">
        <Photo src={s.images?.hero || s.image} alt={`${s.name} interior design hero`} class="ga" loading="eager" />
        <Photo src={s.images?.kitchen || s.image} alt={`${s.name} kitchen interior`} class="gb" loading="eager" />
        <Photo src={s.images?.corner || s.image} alt={`${s.name} styled corner`} class="gc" loading="eager" />
        <Photo src={s.images?.detail || s.image} alt={`${s.name} detail interior`} class="gd" loading="eager" />
      </div>
    </section>
  </div>

  <!-- FACTS -->
  <div class="wrap">
    <section style="padding-top:6px">
      <div class="facts">
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg><div><div class="k">Mood</div><div class="v">{s.mood}</div></div></div>
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 7h16M4 12h16M4 17h16"/></svg><div><div class="k">Materials</div><div class="v">{s.materials}</div></div></div>
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><circle cx="8.5" cy="10" r="1"/><circle cx="15" cy="9" r="1"/><circle cx="15.5" cy="14" r="1"/></svg><div><div class="k">Palette</div><div class="v">{s.palette}</div></div></div>
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 11l8-6 8 6v9H4z"/></svg><div><div class="k">Best rooms</div><div class="v">{s.bestRooms}</div></div></div>
      </div>
    </section>
  </div>

  {s.snapshot && s.snapshot.length > 0 && (
    <div class="wrap">
      <section class="snapshot">
        {s.snapshot.map((item) => (
          <div class="snapitem">
            <div class="k">{item.label}</div>
            <div class="v">{item.value}</div>
          </div>
        ))}
      </section>
    </div>
  )}

  {s.definition && (
    <div class="wrap">
      <section class="explain">
        <div>
          <h2>{s.definition.title}</h2>
          {s.definition.body.map((p) => <p>{p}</p>)}
        </div>
        <div class="explaincards">
          {s.definition.callouts.map((c) => (
            <div class="explaincard">
              <b>{c.title}</b>
              <p>{c.text}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  )}

  {s.features && s.features.length > 0 && (
    <div class="wrap">
      <section class="makes">
        <div>
          <h2>Key features of {s.name.toLowerCase()} interiors</h2>
          {s.features.map((f) => (
            <div class="feat">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 7h16M4 12h10M4 17h16"/></svg>
              <div><b>{f.title}</b><p>{f.desc}</p></div>
            </div>
          ))}
        </div>
        <div class="board"><Photo src={s.images?.materialBoard || s.image} alt={`${s.name} material board`} /><div class="cap">Material board</div></div>
      </section>
    </div>
  )}

  <div class="wrap">
    <section>
      <h2>{s.name} room ideas</h2>
      <div class="ideas">
        {roomIdeas.map((r) => (
          <a class="idea" href={`/styles/${s.slug}/${r.slug}`}>
            {r.image ? <Photo src={r.image} alt={`${s.name} ${r.name} interior`} /> : <Placeholder tone={r.tone} label={`${s.name} ${r.name}`} />}
            <div class="cap"><span>{r.name}</span><span class="arrow">→</span></div>
          </a>
        ))}
      </div>
    </section>
  </div>

  <div class="wrap">
    <section class="palette-story">
      <div class="sectionhead">
        <h2>Palette and materials</h2>
        <p>{s.colorGuide?.intro || 'Use the palette and material mix together: color sets the mood, while texture makes the style feel real in the room.'}</p>
      </div>
      <div class="palette-material-grid">
        <div>
          <h3>Color roles</h3>
          <div class="palette-roles">
          {swatches.map((c) => (
            <div class="palette-role">
              <div class="chip-sw" style={`background:${c.hex}`}></div>
              <div>
                <b>{c.name}</b>
                {c.desc && <p>{c.desc}</p>}
              </div>
            </div>
          ))}
          </div>
        </div>
        <div>
          <h3>Texture roles</h3>
          <div class="material-roles">
          {materialTiles.map((m) => (
            <div class="material-role">
              {m.image ? <Photo src={m.image} alt={`${m.label} material`} /> : <Placeholder tone={m.tone} label="" />}
              <div>
                <b>{m.label}</b>
                {m.desc && <p>{m.desc}</p>}
              </div>
            </div>
          ))}
          </div>
        </div>
      </div>
    </section>
  </div>

  {comparisonRows.length > 0 && (
    <div class="wrap">
      <section class="compare">
        <div class="sectionhead">
          <h2>{s.name} vs similar styles</h2>
          <p>{s.compareIntro || 'If you like this look but are not sure what to call it, compare it with nearby styles before you choose furniture or colors.'}</p>
        </div>
        <div class="comparecards">
          {comparisonRows.map((row) => (
            <div class="comparecard">
              <div class="comparetop">
                <span>Similar style</span>
                {row.href ? <a href={row.href}>{row.style}</a> : <b>{row.style}</b>}
              </div>
              <div class="comparepoint">
                <span>How it usually feels</span>
                <p>{row.feels || row.difference}</p>
              </div>
              <div class="comparepoint strong">
                <span>Choose {s.name} if</span>
                <p>{row.modernRustic || row.difference}</p>
              </div>
              {row.signal && (
                <div class="comparepoint">
                  <span>Visual signal</span>
                  <p>{row.signal}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    </div>
  )}

  {s.shopGuide && s.shopGuide.length > 0 && (
    <div class="wrap">
      <section class="guideblock">
        <div class="sectionhead">
          <h2>Pieces to look for</h2>
          <p>{s.shopGuideIntro || `You do not need to buy a complete matching set. A few right pieces can carry the ${s.name.toLowerCase()} mood.`}</p>
        </div>
        <div class="shopguide">
          {s.shopGuide.map((item) => (
            <article class="piececard">
              {item.image && <img src={item.image} alt={`${item.title} for ${s.name} interior design`} loading="lazy" />}
              <div>
                <b>{item.title}</b>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  )}

  {showShop && s.shop && s.shop.length > 0 && (
    <div class="wrap">
      <section id="shop">
        <h2>Shop the look</h2>
        <div class="shopgrid">
          {s.shop.map((name, i) => (
            <div class="shopitem">
              <div class="top">
                <svg class="bm" viewBox="0 0 24 24" fill="none" stroke="#8a857c" stroke-width="1.6"><path d="M6 3h12v18l-6-4-6 4z"/></svg>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" set:html={icon(shopIcons[i % shopIcons.length])}></svg>
              </div>
              <div class="lbl">{name}</div>
            </div>
          ))}
        </div>
      </section>
    </div>
  )}

  {s.faqs && s.faqs.length > 0 && (
    <div class="wrap">
      <section>
        <h2>{s.name} FAQ</h2>
        <div class="faqlist">
          {s.faqs.map((f) => (
            <details class="faq">
              <summary>{f.q}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6 9l6 6 6-6"/></svg></summary>
              <div class="faq-a">{f.a}</div>
            </details>
          ))}
        </div>
      </section>
    </div>
  )}

  {related.length > 0 && (
    <div class="wrap">
      <section style="padding-bottom:56px">
        <h2>Explore related styles</h2>
        <div class="row4">
          {related.map((r) => (
            <a class="scard" href={`/styles/${r.slug}`}>
              {r.image ? <Photo src={r.image} alt={`${r.name} interior design`} /> : <Placeholder tone={r.tone} label={r.name} />}
              <div class="cap"><b>{r.name}</b><span class="arrow">→</span></div>
            </a>
          ))}
        </div>
      </section>
    </div>
  )}

  <script>
    const KEY = 'ii_saved_styles';
    const btn = document.getElementById('savebtn');
    if (btn) {
      const slug = btn.dataset.slug;
      const lbl = btn.querySelector('.savelbl');
      const get = () => { try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch { return []; } };
      const set = (a) => localStorage.setItem(KEY, JSON.stringify(a));
      const paint = () => {
        const on = get().includes(slug);
        btn.classList.toggle('saved', on);
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
        if (lbl) lbl.textContent = on ? 'Saved' : 'Save style';
      };
      btn.addEventListener('click', () => {
        let a = get();
        a = a.includes(slug) ? a.filter((x) => x !== slug) : [...a, slug];
        set(a);
        paint();
      });
      paint();
    }
  </script>
</BaseLayout>
