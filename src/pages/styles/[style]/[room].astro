---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Placeholder from '../../../components/Placeholder.astro';
import Photo from '../../../components/Photo.astro';
import { combos } from '../../../data/combos.js';
import { getStyle } from '../../../data/styles.js';
import { getRoom } from '../../../data/rooms.js';

export function getStaticPaths() {
  return combos.map((c) => ({ params: { style: c.styleSlug, room: c.roomSlug }, props: { combo: c } }));
}

const { combo: c } = Astro.props;
const style = getStyle(c.styleSlug);
const room = getRoom(c.roomSlug);
const details = c.details || {};
const heroImages = details.heroImages || [
  { image: c.image, alt: `${c.title} interior`, class: 'ga' },
  { image: style?.images?.detail, alt: `${c.styleName} detail`, class: 'gb' },
  { image: style?.images?.corner, alt: `${c.styleName} room corner`, class: 'gc' },
  { image: style?.images?.materialBoard, alt: `${c.styleName} palette and materials`, class: 'gd' },
].filter((item) => item.image);

// Sibling combos in the same style (other rooms) for related links.
const siblings = combos.filter((x) => x.styleSlug === c.styleSlug && x.roomSlug !== c.roomSlug);
---
<BaseLayout title={c.metaTitle} description={c.metaDescription} noindex={!c.indexed}>
  <div class="wrap">
    <div class="crumb">
      <a href="/styles">Styles</a> / <a href={`/styles/${c.styleSlug}`}>{c.styleName}</a> / {c.roomName}
    </div>

    <!-- HERO -->
    <section class="hubhero">
      <div>
        <div class="eyebrow">Style + room</div>
        <h1>{c.styleName} {c.roomName} Interior Design</h1>
        <p class="sub">{details.heroText || `Ideas, layouts, colors and materials for a ${c.styleName.toLowerCase()} ${c.roomName.toLowerCase()} — plus the pieces that make the look work.`}</p>
        <div class="cta">
          <a class="btn" href={`/styles/${c.styleSlug}`}>Explore {c.styleName} →</a>
          <a class="btn ghost" href={`/rooms/${c.roomSlug}`}>All {c.roomName.toLowerCase()} ideas →</a>
        </div>
      </div>
      <div class="hubcollage">
        {heroImages.map((img, i) => (
          img.image
            ? <Photo src={img.image} alt={img.alt || c.title} class={img.class} loading={i === 0 ? 'eager' : 'lazy'} />
            : <Placeholder tone={i === 0 ? c.tone : 'stone'} label={i === 0 ? c.title : ''} class={img.class} />
        ))}
      </div>
    </section>
  </div>

  <!-- FACTS -->
  <div class="wrap">
    <section style="padding-top:6px">
      <div class="facts">
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg><div><div class="k">Style</div><div class="v">{c.styleName}</div></div></div>
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 11l8-6 8 6v9H4z"/></svg><div><div class="k">Room</div><div class="v">{c.roomName}</div></div></div>
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 7h16M4 12h16M4 17h16"/></svg><div><div class="k">Materials</div><div class="v">{style?.materials || '—'}</div></div></div>
        <div class="fact"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><circle cx="8.5" cy="10" r="1"/><circle cx="15" cy="9" r="1"/><circle cx="15.5" cy="14" r="1"/></svg><div><div class="k">Palette</div><div class="v">{style?.palette || '—'}</div></div></div>
      </div>
    </section>
  </div>

  <!-- INTRO -->
  <div class="wrap">
    <section>
      <div class="prose">
        <h2>Designing a {c.styleName.toLowerCase()} {c.roomName.toLowerCase()}</h2>
        {details.intro ? (
          details.intro.map((p) => <p>{p}</p>)
        ) : (
          <p>
            A {c.styleName.toLowerCase()} {c.roomName.toLowerCase()} blends the {c.styleName.toLowerCase()} look —
            {style?.mood ? ` ${style.mood.toLowerCase()},` : ''} {style?.materials?.toLowerCase() || 'natural materials'} —
            with layouts and details that suit a {c.roomName.toLowerCase()}. Start with the palette,
            anchor the room around a focal point, then layer in texture and lighting.
          </p>
        )}
      </div>
    </section>
  </div>

  {details.variations && details.variations.length > 0 && (
    <div class="wrap">
      <section>
        <div class="sectionhead">
          <h2>{c.styleName} {c.roomName.toLowerCase()} variations</h2>
          <p>Use these examples to choose the version of the style that fits your architecture, light and square footage.</p>
        </div>
        <div class="combo-slider" data-combo-slider>
          <div class="combo-stage">
            {details.variations.map((v, i) => (
              <article class={`combo-slide ${i === 0 ? 'active' : ''}`} data-slide={i}>
                <Photo src={v.image} alt={`${v.title} ${c.title}`} loading={i === 0 ? 'eager' : 'lazy'} />
                <div class="combo-slide-caption">
                  <span>{String(i + 1).padStart(2, '0')}</span>
                  <div><b>{v.title}</b><p>{v.text}</p></div>
                </div>
              </article>
            ))}
            <button class="combo-nav combo-prev" type="button" aria-label="Previous variation" data-prev>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 5l-7 7 7 7"/></svg>
            </button>
            <button class="combo-nav combo-next" type="button" aria-label="Next variation" data-next>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
          <div class="combo-slider-bar">
            <div class="combo-dots">
              {details.variations.map((v, i) => (
                <button class={`combo-dot ${i === 0 ? 'active' : ''}`} type="button" data-dot={i} aria-label={`Show ${v.title}`}></button>
              ))}
            </div>
            <div class="combo-count"><span data-current>01</span> / {String(details.variations.length).padStart(2, '0')}</div>
          </div>
        </div>
      </section>
    </div>
  )}

  {details.layout && details.layout.length > 0 && (
    <div class="wrap">
      <section>
        <div class="sectionhead">
          <h2>{c.roomName} layout rules for {c.styleName.toLowerCase()}</h2>
          <p>Use the style where it helps the room work: seating, circulation, focal point and material balance.</p>
        </div>
        <div class="textgrid">
          {details.layout.map((item) => (
            <div class="textcard">
              <b>{item.title}</b>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  )}

  {style?.swatches && style.swatches.length > 0 && (
    <div class="wrap">
      <section class="combo-palette">
        <div class="sectionhead">
          <h2>{c.styleName} {c.roomName.toLowerCase()} palette</h2>
          <p>{style.colorGuide?.intro || 'Use the palette as a room system: base colors first, material tones second and accents last.'}</p>
        </div>
        <div class="palette-material-grid">
          <div>
            <h3>Color roles</h3>
            <div class="palette-roles">
              {style.swatches.map((sw) => (
                <div class="palette-role">
                  <div class="chip-sw" style={`background:${sw.hex}`}></div>
                  <div><b>{sw.name}</b><p>{sw.desc}</p></div>
                </div>
              ))}
            </div>
          </div>
          {details.paletteRules && (
            <div>
              <h3>How it works in this room</h3>
              <div class="material-roles">
                {details.paletteRules.map((rule) => (
                  <div class="combo-rule">
                    <span>{rule.title}</span>
                    <p>{rule.text}</p>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    </div>
  )}

  {details.materials && details.materials.length > 0 && (
    <div class="wrap">
      <section>
        <div class="sectionhead">
          <h2>Pieces and materials to prioritize</h2>
          <p>For this room, a few strong choices can carry the style better than adding more decor.</p>
        </div>
        <div class="shopguide">
          {details.materials.map((item) => (
            <div class="piececard">
              <Photo src={item.image} alt={`${item.title} for ${c.title}`} />
              <div>
                <b>{item.title}</b>
                <p>{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  )}

  {details.mistakes && details.mistakes.length > 0 && (
    <div class="wrap">
      <section>
        <div class="sectionhead">
          <h2>Common mistakes in this room</h2>
          <p>Modern rustic living rooms can become heavy fast. These checks keep the room grounded but still breathable.</p>
        </div>
        <div class="mistake-grid">
          {details.mistakes.map((m) => (
            <div class="mistake-card">
              <b>{m.title}</b>
              <p>{m.text}</p>
            </div>
          ))}
        </div>
      </section>
    </div>
  )}

  {details.faqs && details.faqs.length > 0 && (
    <div class="wrap">
      <section>
        <h2>{c.styleName} {c.roomName.toLowerCase()} questions</h2>
        <div class="faqlist">
          {details.faqs.map((f) => (
            <details class="faq">
              <summary>{f.q}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 9l6 6 6-6"/></svg></summary>
              <div class="faq-a">{f.a}</div>
            </details>
          ))}
        </div>
      </section>
    </div>
  )}

  <!-- RELATED COMBOS -->
  {siblings.length > 0 && (
    <div class="wrap">
      <section style="padding-bottom:56px">
        <h2>{c.styleName} in other rooms</h2>
        <div class="row4">
          {siblings.map((s) => (
            <a class="scard" href={s.href}>
              {s.image ? <Photo src={s.image} alt={`${s.title} interior`} /> : <Placeholder tone={s.tone} label={s.roomName} />}
              <div class="cap"><b>{s.roomName}</b><span class="arrow">→</span></div>
            </a>
          ))}
        </div>
      </section>
    </div>
  )}

  {details.variations && details.variations.length > 0 && (
    <script>
      document.querySelectorAll('[data-combo-slider]').forEach((slider) => {
        const slides = Array.from(slider.querySelectorAll('[data-slide]'));
        const dots = Array.from(slider.querySelectorAll('[data-dot]'));
        const current = slider.querySelector('[data-current]');
        const prev = slider.querySelector('[data-prev]');
        const next = slider.querySelector('[data-next]');
        let active = 0;
        const go = (index) => {
          active = (index + slides.length) % slides.length;
          slides.forEach((slide, i) => slide.classList.toggle('active', i === active));
          dots.forEach((dot, i) => dot.classList.toggle('active', i === active));
          if (current) current.textContent = String(active + 1).padStart(2, '0');
        };
        prev?.addEventListener('click', () => go(active - 1));
        next?.addEventListener('click', () => go(active + 1));
        dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));
      });
    </script>
  )}
</BaseLayout>
