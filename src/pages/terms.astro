---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = 'info@imaginaryinteriors.com';
---
<BaseLayout title="Terms of Use — Imaginary Interiors" description="The terms for using Imaginary Interiors.">
  <div class="wrap">
    <section class="hero" style="grid-template-columns:1fr;padding-bottom:10px">
      <div>
        <div class="eyebrow">Legal</div>
        <h1>Terms of Use</h1>
      </div>
    </section>

    <section>
      <div class="prose">
        <p class="updated">Last updated: {/* TODO */} —</p>

        <p>{/* TODO: replace this template with your finalized terms. */}
          By accessing imaginaryinteriors.com you agree to these Terms of Use. Please read them carefully.</p>

        <h2>Use of the site</h2>
        <p>Describe acceptable use of the content and site.</p>

        <h2>Intellectual property</h2>
        <p>Note ownership of the imagery, text and branding on the site.</p>

        <h2>Affiliate disclosure</h2>
        <p>Some links are affiliate links; we may earn a commission on qualifying purchases at no cost to you.</p>

        <h2>Disclaimer</h2>
        <p>Content is provided "as is" for inspiration and information, without warranties.</p>

        <h2>Changes to these terms</h2>
        <p>We may update these terms from time to time. Continued use means you accept the changes.</p>

        <h2>Contact</h2>
        <p>Questions about these terms? Email <a href={`mailto:${email}`}>{email}</a>.</p>
      </div>
    </section>
  </div>
</BaseLayout>
