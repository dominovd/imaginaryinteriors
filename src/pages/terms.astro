---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = 'info@imaginaryinteriors.com';
---
<BaseLayout title="Terms of Use — Imaginary Interiors" description="The terms for using Imaginary Interiors.">
  <div class="wrap">
    <section class="hero" style="grid-template-columns:1fr;padding-bottom:10px">
      <div>
        <div class="eyebrow">Legal</div>
        <h1>Terms of Use</h1>
      </div>
    </section>

    <section>
      <div class="prose">
        <p class="updated">Last updated: July 4, 2026</p>

        <p>
          By accessing imaginaryinteriors.com, you agree to these Terms of Use. Please read them
          carefully. If you do not agree with these terms, you should not use the site.</p>

        <h2>Use of the site</h2>
        <p>
          Imaginary Interiors is provided for inspiration, education and general design reference.
          You may browse the site, save ideas on your device and share links to our pages. You agree
          not to misuse the site, interfere with its operation, attempt unauthorized access or use
          the content in a way that violates applicable law.</p>

        <h2>Intellectual property</h2>
        <p>
          The Imaginary Interiors name, branding, page design, written content, generated imagery
          and other materials on the site are owned by Imaginary Interiors or used with permission,
          unless otherwise stated. You may not copy, republish, sell or redistribute substantial
          portions of the site without written permission.</p>

        <h2>Imagery and content</h2>
        <p>
          Some imagery and ideas on the site are illustrative and intended as visual concepts rather
          than exact product, construction or safety guidance. Always verify dimensions, materials,
          availability, building requirements and professional recommendations before making design
          or purchasing decisions.</p>

        <h2>Affiliate disclosure</h2>
        <p>
          Some links may be affiliate links. If you click a link and make a qualifying purchase, we
          may earn a commission at no additional cost to you. Affiliate relationships do not
          determine every item we mention, and we aim to keep recommendations useful and relevant.</p>

        <h2>Disclaimer</h2>
        <p>
          The site and its content are provided "as is" for inspiration and information, without
          warranties of any kind. We do not guarantee that content will be accurate, complete,
          available, error-free or suitable for your specific project.</p>

        <h2>Limitation of liability</h2>
        <p>
          To the fullest extent permitted by law, Imaginary Interiors will not be liable for any
          indirect, incidental, consequential or special damages arising from your use of the site,
          third-party links or decisions made based on site content.</p>

        <h2>Changes to these terms</h2>
        <p>We may update these terms from time to time. Continued use means you accept the changes.</p>

        <h2>Contact</h2>
        <p>Questions about these terms? Email <a href={`mailto:${email}`}>{email}</a>.</p>
      </div>
    </section>
  </div>
</BaseLayout>
